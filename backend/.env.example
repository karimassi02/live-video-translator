# --- Clés API (obligatoires) ---
# Deepgram : https://console.deepgram.com (200 $ de crédit offerts à l'inscription)
DEEPGRAM_API_KEY=
# DeepL : https://www.deepl.com/pro-api (plan Developer gratuit : crédit unique de 1M caractères)
DEEPL_API_KEY=

# --- Langues ---
SOURCE_LANG=fr
# Codes DeepL : EN-GB, EN-US, DE, ES, IT...
TARGET_LANG=EN-GB

# --- STT ---
# nova-2 est un bon défaut pour le français en streaming.
DEEPGRAM_MODEL=nova-2

# --- Réglages avancés ---
# Fréquence max de traduction des sous-titres partiels (secondes)
PARTIAL_TRANSLATE_INTERVAL=0.7
PORT=8710
